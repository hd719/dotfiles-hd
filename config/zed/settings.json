// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diagnostics": {
    "button": false
  },
  "languages": {
    "Go": {
      "show_edit_predictions": false
    }
  },
  "disable_ai": true,
  "debugger": {
    "button": false,
    "dock": "right",
  },
  "collaboration_panel": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "context_servers": {
    "postgres-context-server": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
  },
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 100.0,
  "buffer_font_features": {
    "calt": true,
  },
  "agent_ui_font_size": 14.5,
  "ui_font_weight": 100.0,
  "outline_panel": {
    "button": false,
    "dock": "right",
  },
  "agent": {
    "button": false,
    "default_profile": "write",
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "speed": "standard",
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "xhigh",
    },
    "sidebar_side": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "ssh_connections": [
    {
      "host": "mac-mini-lan",
      "args": [],
      "projects": [
        {
          "paths": ["/Users/h/./"],
        },
      ],
    },
    {
      "host": "forgejo-truenas-lan",
      "args": [],
      "projects": [],
    },
  ],
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "auto_install_extensions": {
    "toml": true,
    "dockerfile": true,
    "docker-compose": true,
    "terraform": true,
    "go": true,
    "graphql": true,
    "prisma": true,
    "python": true,
    "sql": true,
    "latex": true,
    "ssh-config": true,
    "tmux": true,
    "markdownlint": true,
    "cspell": true,
  },
  "vim_mode": true,
  "terminal": {
    "button": false,
    "dock": "left",
    "font_size": 13.5,
    "font_family": "Maple Mono NF",
    "cursor_shape": "bar",
    "blinking": "on",
  },
  "project_panel": {
    "button": false,
    "dock": "left",
    "auto_fold_dirs": false,
  },
  "preview_tabs": {
    "enabled": false,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false,
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "gutter": {
    "line_numbers": true,
  },
  "relative_line_numbers": "enabled",
  "minimap": {
    "show": "never",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
