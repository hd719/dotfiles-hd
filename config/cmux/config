# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

palette = 0=#1D1F20
palette = 1=#EB605A
palette = 2=#88FB8D
palette = 3=#F8D85D
palette = 4=#68C1F9
palette = 5=#EB5181
palette = 6=#8FF8DB
palette = 7=#FEFEFE
palette = 8=#b2b2b2
palette = 9=#EB554E
palette = 10=#8EEDB2
palette = 11=#F9DD6E
palette = 12=#68C1F8
palette = 13=#EB5080
palette = 14=#8FF8DB
palette = 15=#FEFEFE
background = #282935
foreground = #EFEFEB
cursor-color = #E9E9E9
selection-background = #9ABACE
selection-foreground = #000001

font-family = CaskaydiaCove Nerd Font Propo
font-style = SemiBold
font-size = 13

window-decoration = true
window-padding-x = 10
window-padding-y = 5
fullscreen=true
macos-non-native-fullscreen=visible-menu
window-save-state = always

gtk-titlebar = true
gtk-tabs-location = top

cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor
cursor-color = #40fdbd

macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = hidden

mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

adjust-cell-height = 20%
adjust-cell-width = 0%

# keybindings
keybind = opt+r=reload_config
keybind = opt+s=close_surface
keybind = opt+n=new_window
# tabs
keybind = opt+t=new_tab
keybind = opt+n=next_tab
keybind = opt+b=previous_tab
keybind = cmd+s>comma=move_tab:-1
keybind = cmd+s>period=move_tab:1
