# Hamel Nord, matched to Zed's active Hamel Nord Blur theme.
palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#88c0d0
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0
palette = 8=#4c566a
palette = 9=#bf616a
palette = 10=#a3be8c
palette = 11=#ebcb8b
palette = 12=#88c0d0
palette = 13=#b48ead
palette = 14=#add3d2
palette = 15=#d8dee9
background = #3b4252
foreground = #d8dee9
cursor-color = #88c0d0
selection-background = #4c566a
selection-foreground = #d8dee9

# Use an 88% Hamel Nord Blur background with a slightly stronger blur.
# Applying opacity to explicit cells keeps Neovim and other full-screen
# terminal apps blurred.
background-opacity = 0.88
background-opacity-cells = true
background-blur = 30

font-family = Maple Mono NF
font-family = Hasklug Nerd Font
font-style = SemiBold
font-size = 13.5

window-decoration = true
window-padding-x = 10
window-padding-y = 5
fullscreen = true
macos-non-native-fullscreen = visible-menu
window-save-state = always

cursor-style = bar
cursor-style-blink = true
shell-integration-features = no-cursor

macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden

mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# keybindings
keybind = opt+r=reload_config
keybind = opt+s=close_surface
keybind = opt+shift+n=new_window
# tabs
keybind = opt+t=new_tab
keybind = opt+n=next_tab
keybind = opt+b=previous_tab
keybind = cmd+s>comma=move_tab:-1
keybind = cmd+s>period=move_tab:1
